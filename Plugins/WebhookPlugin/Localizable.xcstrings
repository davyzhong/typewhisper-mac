  "strings": {
    "Active for all transcriptions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv für alle Transkriptionen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对所有转写生效。"
