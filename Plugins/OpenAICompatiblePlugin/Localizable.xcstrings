{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 密钥"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 密钥安全存储在钥匙串中"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbunden"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已连接"
          }
        }
      }
    },
    "Connection Failed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung fehlgeschlagen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接失败"
          }
        }
