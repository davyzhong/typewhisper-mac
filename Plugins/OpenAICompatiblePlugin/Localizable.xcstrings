      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "z.B. http://localhost:11434"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如 http://localhost:11434"
          }
        }
      }
    },
