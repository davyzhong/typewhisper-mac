{
  "sourceLanguage": "en",
  "strings": {
    "Active for all transcriptions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv für alle Transkriptionen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对所有转写生效。"
          }
        }
      }
    },
    "Add a script to process transcribed text via shell commands.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Skript hinzu, um transkribierten Text per Shell-Befehl zu verarbeiten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加脚本以通过 shell 命令处理转写文本。"
          }
        }
      }
    },
