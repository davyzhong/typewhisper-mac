{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 密钥"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 密钥安全存储在钥匙串中"
          }
        }
      }
    },
    "Copy Prompt": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompt kopieren"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制提示词"
          }
        }
      }
    },
    "Create a new PromptAction with this system prompt and set \"Create Linear Issue\" as the action target:": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle eine neue PromptAction mit diesem Prompt und setze \"Create Linear Issue\" als Aktionsziel:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用此系统提示词创建一个新的 PromptAction，并将操作目标设为\"创建 Linear Issue\"："
          }
        }
      }
    },
    "Create a personal API key at linear.app/settings/api": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstelle einen persönlichen API-Schlüssel unter linear.app/settings/api"
